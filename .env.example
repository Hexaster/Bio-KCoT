# Copy this file to .env and fill in values for your environment.
# .env is ignored by Git.

# API credentials (required only by scripts that call an LLM or judge API)
JUDGE_API_KEY=
OPENAI_API_KEY=
ZENMUX_API_KEY=

# API endpoints. Keep secrets out of config.json.
JUDGE_BASE_URL=https://api.ai-gaochao.cn/v1
OPENAI_BASE_URL=https://api.ai-gaochao.cn/v1
LOCAL_OPENAI_BASE_URL=http://127.0.0.1:8333/v1

# Optional machine-local model overrides. Defaults are in config.json.
QWEN2_5_7B_BASE_MODEL=
QWEN3_4B_BASE_MODEL=
QWEN3_8B_BASE_MODEL=
QWEN3_14B_BASE_MODEL=
BIOMISTRAL_7B_BASE_MODEL=

# Required only when exporting data from a local Reactome Neo4j instance.
NEO4J_URI=bolt://localhost:7688
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Optional alternate configuration file.
BIOKCOT_CONFIG=

# Optional path overrides for large/local artifacts.
TEST_DATA_DIR=
RL_DATASET=
SFT_KG_ADAPTER=
SFT_KG_MERGED=
GRPO_NOKG_OUTPUT=
GRPO_KG_OUTPUT=
GRPO_NOKG_RESUME=
GRPO_KG_CHECKPOINT=
